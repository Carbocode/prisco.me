{
  "name": "prisco-website",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:worktree": "bun scripts/setup-worktree.js",
    "dev": "vite",
    "dev:wrangler": "npm run build && wrangler dev --config dist/server/wrangler.json --persist-to .wrangler/state",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run typecheck",
    "ci": "npm run check && npm run test && npm run db:check && npm run build",
    "deploy": "npm run ci && wrangler deploy",
    "deploy:dry": "npm run ci && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --deny-warnings .",
    "lint:fix": "oxlint --type-aware --fix .",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply prisco-website --local",
    "db:migrate:remote": "wrangler d1 migrations apply prisco-website --remote"
  },
